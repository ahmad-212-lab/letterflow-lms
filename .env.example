# LetterFlow - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control!

# ─── NextAuth ───────────────────────────────────────────────
# Set to your production URL on Vercel (e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ─── Firebase Admin SDK ─────────────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com"

# Paste the full private key including -----BEGIN/END PRIVATE KEY-----
# On Vercel: paste the raw multiline key (Vercel handles newlines automatically)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
